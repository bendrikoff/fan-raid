# --- Источник фида ---
# sim | replay | txodds
FEED_SOURCE=sim
# Для FEED_SOURCE=replay
REPLAY_FILE=./recordings/demo.jsonl
REPLAY_SPEED=10
# Для SimFeed: масштаб времени и воспроизводимость.
# 12 → матч ~7.5 реальных минут, окно ответа ~6 сек (играбельно).
# Повысь (напр. 30–60) для быстрых прогонов/демо, понизь (напр. 6–8) для медленного темпа.
SIM_SPEED=12
SIM_SEED=

# --- Режим разработки ---
# true — доступен /api/auth/dev без Telegram
DEV_MODE=true

# Авто-рестарт матча после финального свистка (dev/демо). Пауза перед новым матчем.
MATCH_AUTORESTART=true
MATCH_RESTART_DELAY_MS=8000

# --- Порты ---
SERVER_PORT=8080

# --- Секрет для подписи сессионных токенов сервера ---
SESSION_SECRET=dev-secret-change-me

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- Solana (FEATURE FLAG) ---
SOLANA_ENABLED=false
SOLANA_KEYPAIR_PATH=./solana-keypair.json
SOLANA_RPC_URL=https://api.devnet.solana.com
# Optional treasury wallet for in-app coin top-ups. Empty = server keypair public key.
SOLANA_TOPUP_TREASURY_WALLET=

# --- TxODDS (реальный live feed) ---
# FEED_SOURCE=txodds включает TxOddsFeed вместо SimFeed/ReplayFeed.
# TXODDS_API_URL может быть http(s) endpoint для polling или ws(s) endpoint.
# В URL/subscribe message можно использовать {matchId}; значение берется из TXODDS_MATCH_ID.
TXODDS_API_URL=
TXODDS_SCORES_API_URL=
TXODDS_API_KEY=
TXODDS_BEARER_TOKEN=
TXODDS_MODE=auto
TXODDS_POLL_MS=1000
TXODDS_MATCH_ID=
TXODDS_API_KEY_HEADER=Authorization
TXODDS_API_KEY_PREFIX=Bearer
TXODDS_SUBSCRIBE_MESSAGE=

# TxLINE FreeTier devnet SSE example:
# FEED_SOURCE=txodds
# TXODDS_MODE=sse
# TXODDS_API_URL=https://txline-dev.txodds.com/api/odds/stream?fixtureId={matchId}
# TXODDS_SCORES_API_URL=https://txline-dev.txodds.com/api/scores/stream?fixtureId={matchId}
# TXODDS_MATCH_ID=<optional fixtureId override; leave empty for auto-pick>
# TXODDS_BEARER_TOKEN=<optional; backend can auto-create guest JWT>
# TXODDS_API_KEY=<activated API token from /api/token/activate>
# TXODDS_API_KEY_HEADER=X-Api-Token
# TXODDS_API_KEY_PREFIX=

# Если JSON TxODDS отличается от авто-маппинга, задай dot-path поля.
# Например: TXODDS_ODDS_HOME_PATH=payload.markets.0.outcomes.0.price
TXODDS_PAYLOAD_PATH=
TXODDS_MINUTE_PATH=
TXODDS_TS_PATH=
TXODDS_ODDS_HOME_PATH=
TXODDS_ODDS_DRAW_PATH=
TXODDS_ODDS_AWAY_PATH=
TXODDS_EVENT_TYPE_PATH=
TXODDS_EVENT_TEAM_PATH=
TXODDS_HOME_TEAM_NAME=
TXODDS_AWAY_TEAM_NAME=
